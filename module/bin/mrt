#!/system/bin/sh
set -eu

MODULE_ID="module-reflash-trigger"
MODULE_NAME="Module Reflash Trigger"
MODULE_VERSION="v0.1.1-dev16"
MODULE_VERSION_CODE="10116"
MODULES_DIR="/data/adb/modules"
RUNTIME_DIR="/data/adb/module-reflash-trigger"
BACKUP_DIR="$RUNTIME_DIR/backups"
STATE_DIR="$RUNTIME_DIR/state"
LOG_DIR="$RUNTIME_DIR/logs"
CONFIG_FILE="$RUNTIME_DIR/config.env"
TRIGGER_VERSION="0.0.0-reflash-trigger"
TRIGGER_VERSION_CODE="1"

mkdir -p "$BACKUP_DIR" "$STATE_DIR" "$LOG_DIR" "$STATE_DIR/remote" "$STATE_DIR/fresh" "$STATE_DIR/pending" 2>/dev/null || true
[ -r "$CONFIG_FILE" ] && . "$CONFIG_FILE"

log() { printf '%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date)" "$*" >> "$LOG_DIR/mrt.log" 2>/dev/null || true; }
err() { printf 'ERROR: %s\n' "$*" >&2; }
json_escape() { printf '%s' "${1:-}" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

prop_get() {
  key="$1"; file_path="$2"
  awk -v k="$key" 'BEGIN{FS="="} $1==k {sub(/^[^=]*=/,"",$0); print; exit}' "$file_path" 2>/dev/null || true
}

module_reports_needs_reflash() {
  # Some modules, notably j-hc/ReVanced Morphe modules, expose manager-visible
  # reflash hints inside module.prop description without changing updateJson
  # versionCode. Treat that as a first-class needs_reflash signal.
  desc=$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]' 2>/dev/null || printf '%s' "${1:-}")
  case "$desc" in
    *"needs reflash"*|*"need reflash"*|*"needs_reflash"*|*"reflash required"*) return 0 ;;
    *) return 1 ;;
  esac
}

prop_set() {
  key="$1"; value="$2"; file_path="$3"
  tmp="$file_path.tmp.$$"
  awk -v k="$key" -v v="$value" 'BEGIN{FS=OFS="="; done=0} $1==k {$0=k"="v; done=1} {print} END{if(!done) print k"="v}' "$file_path" > "$tmp"
  chmod --reference="$file_path" "$tmp" 2>/dev/null || chmod 0644 "$tmp"
  chown --reference="$file_path" "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$file_path"
}

has_cmd() { command -v "$1" >/dev/null 2>&1; }
normalize_url() { printf '%s' "${1:-}" | sed 's/ /%20/g'; }
normalize_head() {
  # Keep only stable cache validators. Drop volatile/duplicated hop data.
  awk 'BEGIN{IGNORECASE=1}
    /^etag:/ {gsub(/^[Ee][Tt][Aa][Gg]:[[:space:]]*/, "etag=", $0); print; next}
    /^last-modified:/ {gsub(/^[Ll][Aa][Ss][Tt]-[Mm][Oo][Dd][Ii][Ff][Ii][Ee][Dd]:[[:space:]]*/, "last-modified=", $0); print; next}
    /^content-length:/ {gsub(/^[Cc][Oo][Nn][Tt][Ee][Nn][Tt]-[Ll][Ee][Nn][Gg][Tt][Hh]:[[:space:]]*/, "content-length=", $0); print; next}
  ' | sed 's/[[:space:]]*$//' | sort -u
}
sha256_text() {
  if has_cmd sha256sum; then
    sha256sum | awk '{print $1}'
  elif has_cmd toybox; then
    toybox sha256sum | awk '{print $1}'
  elif has_cmd busybox; then
    busybox sha256sum | awk '{print $1}'
  else
    cksum | awk '{print $1}'
  fi
}

is_uint() { case "${1:-}" in ''|*[!0-9]*) return 1 ;; *) return 0 ;; esac; }
code_cmp() {
  a="${1:-}"; b="${2:-}"
  is_uint "$a" && is_uint "$b" || { printf 'unknown\n'; return 0; }
  awk -v a="$a" -v b="$b" 'BEGIN{a+=0;b+=0;if(a>b)print "gt";else if(a<b)print "lt";else print "eq"}'
}

fetch_url() {
  raw_url="$1"
  url=$(normalize_url "$raw_url")
  if has_cmd curl; then
    curl -fsSL --globoff --max-time "${MRT_FETCH_TIMEOUT:-20}" "$url"
  elif has_cmd wget; then
    wget -qO- "$url"
  elif [ -x /data/adb/magisk/busybox ]; then
    /data/adb/magisk/busybox wget -qO- "$url"
  elif has_cmd busybox; then
    busybox wget -qO- "$url"
  else
    return 127
  fi
}

head_url() {
  raw_url="$1"
  url=$(normalize_url "$raw_url")
  [ "${MRT_USE_ZIP_HEAD:-0}" = "1" ] || return 0
  if has_cmd curl; then
    curl -fsSIL --globoff --max-time "${MRT_FETCH_TIMEOUT:-20}" "$url" 2>/dev/null | normalize_head || true
  else
    return 0
  fi
}

json_field() {
  key="$1"
  sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p; s/.*"'"$key"'"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1
}

module_prop() { printf '%s/%s/module.prop' "$MODULES_DIR" "$1"; }
module_dir() { printf '%s/%s' "$MODULES_DIR" "$1"; }
remote_cache_file() { printf '%s/remote/%s.json' "$STATE_DIR" "$1"; }
fingerprint_file() { printf '%s/remote/%s.fingerprint' "$STATE_DIR" "$1"; }
fresh_file() { printf '%s/fresh/%s.fingerprint' "$STATE_DIR" "$1"; }
pending_file() { printf '%s/pending/%s.fingerprint' "$STATE_DIR" "$1"; }

list_module_ids() {
  for prop in "$MODULES_DIR"/*/module.prop; do
    [ -f "$prop" ] || continue
    id=$(prop_get id "$prop")
    [ -n "$id" ] || id=$(basename "$(dirname "$prop")")
    printf '%s\n' "$id"
  done | sort
}

is_update_capable() {
  prop="$1"
  [ -f "$prop" ] || return 1
  update_json=$(prop_get updateJson "$prop")
  [ -n "$update_json" ]
}

remote_fetch() {
  id="$1"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || { err "module not found: $id"; return 2; }
  url=$(prop_get updateJson "$prop")
  [ -n "$url" ] || { err "module has no updateJson: $id"; return 3; }
  json=$(fetch_url "$url") || { err "fetch failed: $url"; return 4; }
  rcfile=$(remote_cache_file "$id")
  printf '%s\n' "$json" > "$rcfile"
  r_version=$(printf '%s\n' "$json" | json_field version || true)
  r_code=$(printf '%s\n' "$json" | json_field versionCode || true)
  r_zip=$(printf '%s\n' "$json" | json_field zipUrl || true)
  norm_update_url=$(normalize_url "$url")
  fp_payload="fingerprintVersion=dev7-stable-v1
updateJson=$norm_update_url
json=$json
"
  if [ -n "$r_zip" ]; then
    h=$(head_url "$r_zip" || true)
    fp_payload="$fp_payload
zipHead=$h
"
  fi
  fp=$(printf '%s' "$fp_payload" | sha256_text)
  printf '%s\n' "$fp" > "$(fingerprint_file "$id")"
  printf 'remote_version=%s\nremote_versionCode=%s\nremote_zipUrl=%s\nremote_fingerprint=%s\n' "$r_version" "$r_code" "$r_zip" "$fp"
  return 0
}

status_one() {
  id="$1"; online="${2:-0}"; format="${3:-text}"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || { err "module not found: $id"; return 2; }
  dir=$(module_dir "$id")
  name=$(prop_get name "$prop")
  version=$(prop_get version "$prop")
  versionCode=$(prop_get versionCode "$prop")
  updateJson=$(prop_get updateJson "$prop")
  description=$(prop_get description "$prop")
  moduleNeedsReflashMarker="false"; module_reports_needs_reflash "$description" && moduleNeedsReflashMarker="true"
  disabled="false"; [ -e "$dir/disable" ] && disabled="true"
  remove_marker="false"; [ -e "$dir/remove" ] && remove_marker="true"
  self="false"; [ "$id" = "$MODULE_ID" ] && self="true"
  update_capable="false"; [ -n "$updateJson" ] && update_capable="true"
  remoteVersion=""; remoteCode=""; remoteFingerprint=""; zipUrl=""; fetchStatus="not_requested"

  if [ "$online" = "1" ] && [ -n "$updateJson" ]; then
    rf=$(remote_fetch "$id" 2>/dev/null || true)
    if [ -n "$rf" ]; then
      fetchStatus="ok"
      remoteVersion=$(printf '%s\n' "$rf" | awk -F= '$1=="remote_version"{sub(/^[^=]*=/,"",$0);print;exit}' || true)
      remoteCode=$(printf '%s\n' "$rf" | awk -F= '$1=="remote_versionCode"{sub(/^[^=]*=/,"",$0);print;exit}' || true)
      zipUrl=$(printf '%s\n' "$rf" | awk -F= '$1=="remote_zipUrl"{sub(/^[^=]*=/,"",$0);print;exit}' || true)
      remoteFingerprint=$(printf '%s\n' "$rf" | awk -F= '$1=="remote_fingerprint"{sub(/^[^=]*=/,"",$0);print;exit}' || true)
    else
      fetchStatus="failed"
    fi
  elif [ -f "$(fingerprint_file "$id")" ]; then
    remoteFingerprint=$(cat "$(fingerprint_file "$id")" 2>/dev/null || true)
  fi

  freshFingerprint=""; [ -f "$(fresh_file "$id")" ] && freshFingerprint=$(cat "$(fresh_file "$id")" 2>/dev/null || true)
  pendingFingerprint=""; [ -f "$(pending_file "$id")" ] && pendingFingerprint=$(cat "$(pending_file "$id")" 2>/dev/null || true)
  status="local_only"; triggerable="false"; needs_reflash="false"; reason="no_updateJson"

  if [ "$update_capable" = "true" ]; then
    status="update_capable"; triggerable="true"; reason="manual_reflash_trigger_available"
    if [ "$self" = "true" ]; then
      triggerable="false"; status="self"; reason="self_update_managed_by_manager"
    elif [ "$disabled" = "true" ] || [ "$remove_marker" = "true" ]; then
      triggerable="false"; status="blocked"; reason="disable_or_remove_marker_present"
    elif [ "$moduleNeedsReflashMarker" = "true" ] && { [ "$fetchStatus" = "failed" ] || [ -z "$remoteCode" ] || [ -z "$versionCode" ]; }; then
      status="needs_reflash"; needs_reflash="true"; reason="module_reported_needs_reflash_marker"
    elif [ "$online" = "1" ] && [ "$fetchStatus" = "failed" ]; then
      status="remote_fetch_failed"; reason="online_metadata_unavailable"; triggerable="true"
    elif [ -n "$remoteCode" ] && [ -n "$versionCode" ]; then
      cmp=$(code_cmp "$remoteCode" "$versionCode")
      if [ "$cmp" = "gt" ]; then
        status="update_available"; triggerable="false"; needs_reflash="false"; reason="manager_update_already_available"
      elif [ "$cmp" = "eq" ]; then
        status="same_remote_versionCode"
        if [ "$moduleNeedsReflashMarker" = "true" ]; then
          status="needs_reflash"; needs_reflash="true"; reason="module_reported_needs_reflash_marker"
        elif [ -z "$remoteFingerprint" ]; then
          reason="same_code_no_fingerprint"
        elif [ -z "$freshFingerprint" ]; then
          status="reflash_baseline_unknown"; reason="no_fresh_baseline_known"
          [ "${MRT_AUTO_BASELINE_UNKNOWN:-0}" = "1" ] && needs_reflash="true"
        elif [ "$remoteFingerprint" != "$freshFingerprint" ]; then
          status="needs_reflash"; needs_reflash="true"; reason="remote_fingerprint_changed_since_last_fresh"
        else
          status="fresh"; reason="remote_fingerprint_matches_fresh_baseline"
        fi
      elif [ "$cmp" = "lt" ]; then
        status="local_newer_than_remote"; triggerable="false"; reason="local_versionCode_higher_than_remote"
      else
        status="code_compare_unknown"; reason="non_numeric_versionCode"; triggerable="true"
      fi
    elif [ "$moduleNeedsReflashMarker" = "true" ]; then
      status="needs_reflash"; needs_reflash="true"; reason="module_reported_needs_reflash_marker"
    fi
  fi

  if [ "$format" = "json" ]; then
    printf '{"id":"%s","name":"%s","version":"%s","versionCode":"%s","updateJson":"%s","description":"%s","moduleNeedsReflashMarker":%s,"self":%s,"disabled":%s,"remove_marker":%s,"update_capable":%s,"fetchStatus":"%s","remoteVersion":"%s","remoteCode":"%s","remoteFingerprint":"%s","freshFingerprint":"%s","pendingFingerprint":"%s","triggerable":%s,"needs_reflash":%s,"status":"%s","reason":"%s"}\n' \
      "$(json_escape "$id")" "$(json_escape "$name")" "$(json_escape "$version")" "$(json_escape "$versionCode")" "$(json_escape "$updateJson")" "$(json_escape "$description")" "$moduleNeedsReflashMarker" \
      "$self" "$disabled" "$remove_marker" "$update_capable" "$(json_escape "$fetchStatus")" "$(json_escape "$remoteVersion")" "$(json_escape "$remoteCode")" "$(json_escape "$remoteFingerprint")" "$(json_escape "$freshFingerprint")" "$(json_escape "$pendingFingerprint")" \
      "$triggerable" "$needs_reflash" "$(json_escape "$status")" "$(json_escape "$reason")"
  else
    printf 'module_dir=%s\n' "$dir"
    printf '  id=%s\n  name=%s\n  version=%s\n  versionCode=%s\n  updateJson=%s\n' "$id" "$name" "$version" "$versionCode" "$updateJson"
    printf '  moduleNeedsReflashMarker=%s\n' "$moduleNeedsReflashMarker"
    [ "$moduleNeedsReflashMarker" = "true" ] && printf '  moduleNeedsReflashText=%s\n' "$description"
    printf '  status=%s\n  reason=%s\n  triggerable=%s\n  needs_reflash=%s\n' "$status" "$reason" "$triggerable" "$needs_reflash"
    [ -n "$remoteCode" ] && printf '  remoteVersion=%s\n  remoteCode=%s\n' "$remoteVersion" "$remoteCode"
  fi
  return 0
}

scan() {
  online="${1:-0}"; format="${2:-text}"
  count=0; first=1
  [ "$format" = "json" ] && printf '['
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    if [ "$format" = "json" ]; then
      [ "$first" = "1" ] || printf ','
      if ! status_one "$id" "$online" json; then
        printf '{"id":"%s","status":"scan_error","triggerable":false,"needs_reflash":false}' "$(json_escape "$id")"
      fi
      first=0
    else
      if ! status_one "$id" "$online" text; then
        printf 'module_id=%s\n  status=scan_error\n  triggerable=false\n  needs_reflash=false\n' "$id"
      fi
    fi
    count=$((count+1))
  done
  if [ "$format" = "json" ]; then printf ']\n'; else printf 'targets=%s\n' "$count"; fi
  return 0
}

count_update_capable() {
  c=0
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    c=$((c+1))
  done
  printf '%s\n' "$c"
}

require_triggerable_static() {
  id="$1"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || { err "module not found: $id"; exit 2; }
  [ "$id" != "$MODULE_ID" ] || { err "refusing to trigger self module: $id"; exit 3; }
  [ -n "$(prop_get updateJson "$prop")" ] || { err "module has no updateJson: $id"; exit 4; }
  dir=$(module_dir "$id")
  [ ! -e "$dir/disable" ] || { err "module disabled marker present: $id"; exit 5; }
  [ ! -e "$dir/remove" ] || { err "module remove marker present: $id"; exit 6; }
}

backup_prop() {
  id="$1"; backup_id="$2"
  prop=$(module_prop "$id")
  dest="$BACKUP_DIR/$backup_id/$id"
  mkdir -p "$dest"
  cp -p "$prop" "$dest/module.prop"
  printf '%s\n' "$prop" > "$dest/source_path.txt"
  printf '%s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date)" > "$dest/created_at.txt"
  [ -f "$(fingerprint_file "$id")" ] && cp -p "$(fingerprint_file "$id")" "$dest/remote.fingerprint"
}

trigger_one() {
  id="$1"; assume_yes="${2:-0}"; force="${3:-0}"
  require_triggerable_static "$id"
  if [ "$force" != "1" ]; then
    js=$(status_one "$id" 1 json || status_one "$id" 0 json)
    triggerable=$(printf '%s' "$js" | sed -n 's/.*"triggerable":\(true\|false\).*/\1/p')
    status=$(printf '%s' "$js" | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')
    [ "$triggerable" = "true" ] || { err "module not triggerable without --force: $id status=$status"; exit 7; }
  fi
  prop=$(module_prop "$id")
  old_version=$(prop_get version "$prop")
  old_code=$(prop_get versionCode "$prop")
  backup_id=$(date '+%Y%m%d_%H%M%S')
  if [ "$assume_yes" != "1" ]; then
    printf 'About to trigger module=%s old_version=%s old_versionCode=%s\n' "$id" "$old_version" "$old_code"
    printf 'Type YES to continue: '
    read ans
    [ "$ans" = "YES" ] || { err "aborted"; exit 10; }
  fi
  remote_fetch "$id" >/dev/null 2>&1 || true
  backup_prop "$id" "$backup_id"
  [ -f "$(fingerprint_file "$id")" ] && cp -p "$(fingerprint_file "$id")" "$(pending_file "$id")"
  prop_set version "$TRIGGER_VERSION" "$prop"
  prop_set versionCode "$TRIGGER_VERSION_CODE" "$prop"
  sync 2>/dev/null || true
  printf 'UPDATED module=%s version=%s->%s versionCode=%s->%s\n' "$id" "$old_version" "$TRIGGER_VERSION" "$old_code" "$TRIGGER_VERSION_CODE"
  printf 'backup_dir=%s/%s/%s\n' "$BACKUP_DIR" "$backup_id" "$id"
  printf 'ACTION: close and reopen your root/module manager, then run its normal online update/reflash.\n'
  log "trigger module=$id backup_id=$backup_id old_code=$old_code"
}

restore_latest() {
  id="$1"
  latest=$(ls -1d "$BACKUP_DIR"/*/"$id" 2>/dev/null | sort | tail -n 1 || true)
  [ -n "$latest" ] || { err "no backup found for $id"; exit 2; }
  cp -p "$latest/module.prop" "$(module_prop "$id")"
  sync 2>/dev/null || true
  printf 'RESTORED module=%s from=%s\n' "$id" "$latest"
  log "restore_latest module=$id from=$latest"
}

mark_fresh() {
  id="$1"; mode="${2:-remote}"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || { err "module not found: $id"; exit 2; }
  if [ "$mode" != "cached" ]; then
    remote_fetch "$id" >/dev/null 2>&1 || true
  fi
  if [ -f "$(fingerprint_file "$id")" ]; then
    cp -p "$(fingerprint_file "$id")" "$(fresh_file "$id")"
  elif [ -f "$(pending_file "$id")" ]; then
    cp -p "$(pending_file "$id")" "$(fresh_file "$id")"
  else
    err "cannot determine remote fingerprint for $id"
    exit 3
  fi
  rm -f "$(pending_file "$id")" 2>/dev/null || true
  printf 'MARKED_FRESH module=%s fingerprint=%s\n' "$id" "$(cat "$(fresh_file "$id")")"
  log "mark_fresh module=$id mode=$mode"
}

auto_profile_match() {
  id="$1"
  profile="${2:-${MRT_AUTO_TRIGGER_PROFILE:-}}"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || return 1
  blob=$( {
  auto_profile_excluded "$id" "$blob" && return 1
    printf '%s
' "$id"
    prop_get name "$prop"
    prop_get description "$prop"
    prop_get updateJson "$prop"
  } | tr '[:upper:]' '[:lower:]' 2>/dev/null || true )
  case "$profile" in
    morphe|revanced|revanced-morphe)
      case "$blob" in
        *morphe*|*revanced-magisk-module*|*revanced*|*j-hc/revanced*) return 0 ;;
      esac
      ;;
  esac
  return 1
}

auto_profile_ids() {
  profile="${1:-morphe}"
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    auto_profile_match "$id" "$profile" && printf '%s
' "$id"
  done | sort
}



auto_profile_is_self_module() {
  case "${1:-}" in
    module-reflash-trigger|module_reflash_trigger|mrt|MRT) return 0 ;;
  esac
  case "$(printf '%s' "${2:-}" | tr '[:upper:]' '[:lower:]')" in
    *module-reflash-trigger*|*module\ reflash\ trigger*) return 0 ;;
  esac
  return 1
}

auto_profile_excluded() {
  auto_profile_is_self_module "${1:-}" "${2:-}" && return 0
  id="$1"
  blob="${2:-}"
  case "$id" in
    rvmm*|*rvmm*|*zygisk-mount*|*zygisk_mount*) return 0 ;;
  esac
  case "$blob" in
    *rvmm*|*zygisk-mount*|*zygisk_mount*|*mounts\ the\ rvmm*|*mounts-the-rvmm*) return 0 ;;
  esac
  return 1
}

auto_profile_match() {
  id="$1"
  profile="${2:-${MRT_AUTO_TRIGGER_PROFILE:-}}"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || return 1
  blob=$( {
    printf '%s
' "$id"
    prop_get name "$prop"
    prop_get description "$prop"
    prop_get updateJson "$prop"
  } | tr '[:upper:]' '[:lower:]' 2>/dev/null || true )
  auto_profile_excluded "$id" "$blob" && return 1
  case "$profile" in
    morphe|revanced|revanced-morphe)
      case "$blob" in
        *morphe*|*revanced-magisk-module*|*revanced*|*j-hc/revanced*) return 0 ;;
      esac
      ;;
  esac
  return 1
}

auto_profile_ids() {
  profile="${1:-morphe}"
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    auto_profile_match "$id" "$profile" && printf '%s
' "$id"
  done | sort
}

auto_allowed() {
  id="$1"
  [ "${MRT_AUTO_TRIGGER_ENABLED:-0}" = "1" ] || return 1
  for x in ${MRT_AUTO_TRIGGER_MODULE_IDS:-}; do
    [ "$x" = "$id" ] && return 0
  done
  profile="${MRT_AUTO_TRIGGER_PROFILE:-}"
  [ -n "$profile" ] && auto_profile_match "$id" "$profile" && return 0
  return 1
}

auto_trigger() {
  assume_yes="${1:-0}"
  [ "$assume_yes" = "1" ] || { err "auto-trigger requires --yes"; exit 9; }
  count=0
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    auto_allowed "$id" || continue
    js=$(status_one "$id" 1 json)
    needs=$(printf '%s' "$js" | sed -n 's/.*"needs_reflash":\(true\|false\).*/\1/p')
    triggerable=$(printf '%s' "$js" | sed -n 's/.*"triggerable":\(true\|false\).*/\1/p')
    if [ "$needs" = "true" ] && [ "$triggerable" = "true" ]; then
      trigger_one "$id" 1 0
      count=$((count+1))
    fi
  done
  printf 'auto_triggered=%s\n' "$count"
  return 0
}

summary() {
  printf '== %s ==\n' "$MODULE_NAME"
  printf 'version=%s\n' "$MODULE_VERSION"
  printf 'versionCode=%s\n' "$MODULE_VERSION_CODE"
  printf 'runtime=%s\n' "$RUNTIME_DIR"
  printf 'config=%s\n' "$CONFIG_FILE"
  printf 'auto_enabled=%s\n' "${MRT_AUTO_TRIGGER_ENABLED:-0}"
  printf 'auto_allowlist=%s\n' "${MRT_AUTO_TRIGGER_MODULE_IDS:-}"
  printf 'auto_profile=%s\n' "${MRT_AUTO_TRIGGER_PROFILE:-}"
  printf 'auto_on_boot=%s\n' "${MRT_AUTO_TRIGGER_ON_BOOT:-0}"
  printf 'updateJson_capable_modules=%s\n' "$(count_update_capable)"
  return 0
}

write_config_auto() {
  mode="${1:-}"; shift || true
  mkdir -p "$RUNTIME_DIR"
  if [ "$mode" = "--disable" ]; then
    cat > "$CONFIG_FILE" <<EOF
MRT_BOOT_AUTOSCAN=0
MRT_AUTO_TRIGGER_ON_BOOT=0
MRT_AUTO_TRIGGER_ENABLED=0
MRT_AUTO_TRIGGER_MODULE_IDS=""
MRT_AUTO_TRIGGER_PROFILE=""
MRT_AUTO_BASELINE_UNKNOWN=0
MRT_USE_ZIP_HEAD=0
EOF
    printf 'CONFIG_WRITTEN auto_enabled=0 file=%s
' "$CONFIG_FILE"
    return 0
  fi
  if [ "$mode" = "--profile" ] || [ "$mode" = "--morphe" ]; then
    if [ "$mode" = "--morphe" ]; then
      profile="morphe"
    else
      profile="${1:-morphe}"; shift || true
    fi
    on_boot=0
    for arg in "$@"; do
      case "$arg" in --on-boot|--boot) on_boot=1 ;; --manual|--no-boot) on_boot=0 ;; esac
    done
    case "$profile" in morphe|revanced|revanced-morphe) : ;; *) err "unsupported auto profile: $profile"; exit 2 ;; esac
    ids=$(auto_profile_ids "$profile" | tr '
' ' ' | sed 's/[[:space:]]*$//')
    cat > "$CONFIG_FILE" <<EOF
MRT_BOOT_AUTOSCAN=0
MRT_AUTO_TRIGGER_ON_BOOT=$on_boot
MRT_AUTO_TRIGGER_ENABLED=1
MRT_AUTO_TRIGGER_MODULE_IDS="$ids"
MRT_AUTO_TRIGGER_PROFILE="$profile"
MRT_AUTO_BASELINE_UNKNOWN=0
MRT_USE_ZIP_HEAD=0
EOF
    printf 'CONFIG_WRITTEN auto_enabled=1 profile=%s on_boot=%s ids=%s file=%s
' "$profile" "$on_boot" "$ids" "$CONFIG_FILE"
    return 0
  fi
  [ "$mode" = "--enable" ] || { err "config-auto requires --enable <module-id...>, --profile morphe [--on-boot], --morphe [--on-boot] or --disable"; exit 2; }
  [ $# -gt 0 ] || { err "config-auto --enable requires at least one module id"; exit 2; }
  ids="$*"
  cat > "$CONFIG_FILE" <<EOF
MRT_BOOT_AUTOSCAN=0
MRT_AUTO_TRIGGER_ON_BOOT=0
MRT_AUTO_TRIGGER_ENABLED=1
MRT_AUTO_TRIGGER_MODULE_IDS="$ids"
MRT_AUTO_TRIGGER_PROFILE=""
MRT_AUTO_BASELINE_UNKNOWN=0
MRT_USE_ZIP_HEAD=0
EOF
  printf 'CONFIG_WRITTEN auto_enabled=1 ids=%s file=%s
' "$ids" "$CONFIG_FILE"
}

config_show() {
  if [ -f "$CONFIG_FILE" ]; then
    cat "$CONFIG_FILE"
  else
    printf 'config_absent=%s\n' "$CONFIG_FILE"
  fi
}

auto_trigger_dry_run() {
  count=0
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    auto_allowed "$id" || continue
    js=$(status_one "$id" 1 json)
    needs=$(printf '%s' "$js" | sed -n 's/.*"needs_reflash":\(true\|false\).*/\1/p')
    triggerable=$(printf '%s' "$js" | sed -n 's/.*"triggerable":\(true\|false\).*/\1/p')
    status=$(printf '%s' "$js" | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')
    if [ "$needs" = "true" ] && [ "$triggerable" = "true" ]; then
      printf 'WOULD_TRIGGER module=%s status=%s\n' "$id" "$status"
      count=$((count+1))
    else
      printf 'SKIP module=%s status=%s needs_reflash=%s triggerable=%s\n' "$id" "$status" "$needs" "$triggerable"
    fi
  done
  printf 'auto_trigger_dry_run_would_trigger=%s\n' "$count"
}


baseline_show() {
  id="$1"; online="${2:-0}"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || { err "module not found: $id"; exit 2; }
  if [ "$online" = "1" ]; then
    remote_fetch "$id" >/dev/null 2>&1 || true
  fi
  printf '== baseline %s ==\n' "$id"
  printf 'module_dir=%s\n' "$(module_dir "$id")"
  printf 'fresh_file=%s\n' "$(fresh_file "$id")"
  if [ -f "$(fresh_file "$id")" ]; then
    printf 'freshFingerprint=%s\n' "$(cat "$(fresh_file "$id")")"
  else
    printf 'freshFingerprint=\n'
  fi
  printf 'remote_file=%s\n' "$(fingerprint_file "$id")"
  if [ -f "$(fingerprint_file "$id")" ]; then
    printf 'remoteFingerprint=%s\n' "$(cat "$(fingerprint_file "$id")")"
  else
    printf 'remoteFingerprint=\n'
  fi
  printf 'pending_file=%s\n' "$(pending_file "$id")"
  if [ -f "$(pending_file "$id")" ]; then
    printf 'pendingFingerprint=%s\n' "$(cat "$(pending_file "$id")")"
  else
    printf 'pendingFingerprint=\n'
  fi
  printf '\n== status-online ==\n'
  status_one "$id" 1 text || true
  return 0
}

clear_baseline() {
  [ $# -gt 0 ] || { err "clear-baseline requires module id(s)"; exit 2; }
  for id in "$@"; do
    prop=$(module_prop "$id")
    [ -f "$prop" ] || { err "module not found: $id"; exit 2; }
    rm -f "$(fresh_file "$id")" "$(pending_file "$id")" 2>/dev/null || true
    printf 'CLEARED_BASELINE module=%s\n' "$id"
    log "clear_baseline module=$id"
  done
  return 0
}

test_mark_stale() {
  id="$1"
  prop=$(module_prop "$id")
  [ -f "$prop" ] || { err "module not found: $id"; exit 2; }
  [ -n "$(prop_get updateJson "$prop")" ] || { err "module has no updateJson: $id"; exit 3; }
  remote_fetch "$id" >/dev/null 2>&1 || { err "cannot fetch remote fingerprint for $id"; exit 4; }
  ff=$(fresh_file "$id")
  mkdir -p "$(dirname "$ff")"
  if [ -f "$ff" ]; then
    cp -p "$ff" "$ff.bak.$(date '+%Y%m%d_%H%M%S')" 2>/dev/null || true
  fi
  stale="test-stale:$(date '+%Y%m%d_%H%M%S'):$id"
  printf '%s\n' "$stale" > "$ff"
  printf 'TEST_MARKED_STALE module=%s freshFingerprint=%s\n' "$id" "$stale"
  printf 'ACTION: run mrt status-online %s or auto-trigger --dry-run to verify needs_reflash path. Run mark-fresh %s to return to fresh baseline.\n' "$id" "$id"
  log "test_mark_stale module=$id"
  return 0
}


trigger_needed() {
  mode="marker"; action="dry-run"
  while [ $# -gt 0 ]; do
    case "$1" in
      --mode) shift; mode="${1:-marker}" ;;
      --mode=*) mode="${1#--mode=}" ;;
      --marker|--markers|--manager-marker) mode="marker" ;;
      --all) mode="all" ;;
      --dry-run) action="dry-run" ;;
      --yes) action="yes" ;;
      *) err "unknown trigger-needed argument: $1"; exit 2 ;;
    esac
    shift || true
  done
  case "$mode" in marker|all) : ;; *) err "trigger-needed mode must be marker or all"; exit 2 ;; esac
  case "$action" in dry-run|yes) : ;; *) err "trigger-needed action must be dry-run or yes"; exit 2 ;; esac

  count=0; scanned=0
  printf 'trigger_needed_mode=%s\n' "$mode"
  printf 'trigger_needed_action=%s\n' "$action"
  for id in $(list_module_ids); do
    prop=$(module_prop "$id")
    is_update_capable "$prop" || continue
    scanned=$((scanned+1))
    js=$(status_one "$id" 1 json)
    needs=$(printf '%s' "$js" | sed -n 's/.*"needs_reflash":\(true\|false\).*/\1/p')
    marker=$(printf '%s' "$js" | sed -n 's/.*"moduleNeedsReflashMarker":\(true\|false\).*/\1/p')
    triggerable=$(printf '%s' "$js" | sed -n 's/.*"triggerable":\(true\|false\).*/\1/p')
    status=$(printf '%s' "$js" | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')
    reason=$(printf '%s' "$js" | sed -n 's/.*"reason":"\([^"]*\)".*/\1/p')

    eligible="false"
    if [ "$mode" = "marker" ]; then
      [ "$marker" = "true" ] && [ "$needs" = "true" ] && eligible="true"
    else
      [ "$needs" = "true" ] && eligible="true"
    fi

    if [ "$eligible" = "true" ] && [ "$triggerable" = "true" ]; then
      if [ "$action" = "dry-run" ]; then
        printf 'WOULD_TRIGGER module=%s status=%s reason=%s marker=%s\n' "$id" "$status" "$reason" "$marker"
      else
        trigger_one "$id" 1 0
      fi
      count=$((count+1))
    else
      printf 'SKIP module=%s status=%s reason=%s needs_reflash=%s marker=%s triggerable=%s\n' "$id" "$status" "$reason" "$needs" "$marker" "$triggerable"
    fi
  done
  if [ "$action" = "dry-run" ]; then
    printf 'trigger_needed_dry_run_would_trigger=%s\n' "$count"
  else
    printf 'trigger_needed_triggered=%s\n' "$count"
    if [ "$count" -gt 0 ]; then
      printf 'ACTION: close and reopen your root/module manager, then run its normal online update/reflash for triggered modules.\n'
    fi
  fi
  printf 'trigger_needed_scanned=%s\n' "$scanned"
  return 0
}

action_button() {
  printf '== %s Action ==\n' "$MODULE_NAME"
  summary
  printf '\n== trigger manager-reported Needs reflash modules ==\n'
  trigger_needed --mode marker --yes
  printf '\nNOTE: This action only re-enables manager-side online update/reflash by lowering versionCode. It does not download or install third-party module ZIPs.\n'
  printf 'RESULT: MRT_ACTION_TRIGGER_NEEDS_REFLASH_DONE rc=0\n'
  return 0
}

usage() {
  cat <<USAGEEOF
$MODULE_NAME CLI (mrt)

Commands:
  mrt summary
  mrt scan | list             # offline scan of updateJson-capable modules
  mrt scan-json               # offline JSON list
  mrt scan-online             # fetch updateJson and compare versionCode/fingerprint
  mrt scan-online-json
  mrt status <module-id>
  mrt status-online <module-id>
  mrt trigger <module-id>
  mrt trigger --yes <module-id>
  mrt trigger --force --yes <module-id>
  mrt restore-latest <module-id>
  mrt mark-fresh <module-id>
  mrt mark-fresh --cached <module-id>
  mrt baseline-show <module-id>
  mrt baseline-show --online <module-id>
  mrt clear-baseline <module-id...>
  mrt test-mark-stale <module-id>       # test-only: simulate needs_reflash without touching module.prop
  mrt trigger-needed --dry-run [--mode marker|all]
  mrt trigger-needed --yes [--mode marker|all]
  mrt action                            # Magisk Action button path: trigger manager-reported Needs reflash markers
  mrt auto-trigger --dry-run
    mrt auto-trigger --yes                 # replay config-status candidates and trigger them
  mrt auto-ids morphe                   # list installer/profile-matched Morphe/ReVanced ids
  mrt config-show
  mrt config-auto --enable <module-id...>
  mrt config-auto --profile morphe [--on-boot]
  mrt config-auto --disable

Safety:
  - refuses to trigger itself
  - refuses modules without updateJson
  - refuses disabled/remove-marked modules
  - refuses local-newer/update-available modules unless --force is used
  - auto-trigger is off unless MRT_AUTO_TRIGGER_ENABLED=1 and an allowlist/profile permits the module
  - module-reported Needs reflash markers in module.prop description are treated as needs_reflash
  - trigger-needed default mode is marker-only for public-safe Action Button behavior
  - action button triggers manager-reported Needs reflash markers only and never auto-installs ZIPs
  - test-mark-stale only changes MRT baseline state, never module.prop
USAGEEOF
}

cmd="${1:-summary}"


# WebUI v0.1.1-dev16 file-backed scan bridge. Long scans run in the background and
# large JSON output is read in small chunks so Android WebView bridges do not block
# or truncate the module list.
webui_dir() { printf '%s\n' "$RUNTIME_DIR/webui"; }
webui_job_file() { printf '%s\n' "$(webui_dir)/job.env"; }
webui_scan_file() {
  case "${1:-online}" in
    local) printf '%s\n' "$(webui_dir)/scan-local.json" ;;
    online|*) printf '%s\n' "$(webui_dir)/scan-online.json" ;;
  esac
}
webui_err_file() {
  case "${1:-online}" in
    local) printf '%s\n' "$(webui_dir)/scan-local.err" ;;
    online|*) printf '%s\n' "$(webui_dir)/scan-online.err" ;;
  esac
}
webui_write_job() {
  mkdir -p "$(webui_dir)"
  now="$(date +%s 2>/dev/null || echo 0)"
  {
    printf 'status=%s\n' "${1:-unknown}"
    printf 'mode=%s\n' "${2:-}"
    printf 'updated=%s\n' "$now"
    printf 'pid=%s\n' "${3:-}"
    printf 'rc=%s\n' "${4:-}"
    printf 'message=%s\n' "${5:-}"
  } > "$(webui_job_file)"
}
webui_scan_start() {
  mode="${1:-online}"
  case "$mode" in online|local) : ;; *) mode=online ;; esac
  dir="$(webui_dir)"
  mkdir -p "$dir"
  rm -f "$dir/scan-$mode.json.tmp" "$(webui_err_file "$mode")"
  webui_write_job running "$mode" "" "" "started"
  ( "$0" __webui_scan_run "$mode" >/dev/null 2>&1 & echo "started mode=$mode" )
}
webui_scan_run() {
  mode="${1:-online}"
  dir="$(webui_dir)"
  mkdir -p "$dir"
  out="$(webui_scan_file "$mode")"
  err="$(webui_err_file "$mode")"
  tmp="$out.tmp"
  webui_write_job running "$mode" "$$" "" "scan_running"
  if [ "$mode" = "online" ]; then
    if scan 1 json > "$tmp" 2> "$err"; then rc=0; else rc=$?; fi
  else
    if scan 0 json > "$tmp" 2> "$err"; then rc=0; else rc=$?; fi
  fi
  if [ "${rc:-1}" = 0 ]; then
    mv -f "$tmp" "$out"
    bytes="$(wc -c < "$out" 2>/dev/null || echo 0)"
    webui_write_job ok "$mode" "$$" "$rc" "bytes=$bytes"
  else
    rm -f "$tmp"
    webui_write_job failed "$mode" "$$" "$rc" "scan_failed"
  fi
  exit "${rc:-1}"
}
webui_status() {
  mkdir -p "$(webui_dir)"
  job="$(webui_job_file)"
  if [ -s "$job" ]; then cat "$job"; else webui_write_job idle none "" "" "no_job"; cat "$job"; fi
  for mode in online local; do
    f="$(webui_scan_file "$mode")"
    e="$(webui_err_file "$mode")"
    if [ -f "$f" ]; then printf '%s_bytes=%s\n' "$mode" "$(wc -c < "$f" 2>/dev/null || echo 0)"; else printf '%s_bytes=0\n' "$mode"; fi
    if [ -f "$e" ]; then printf '%s_err_bytes=%s\n' "$mode" "$(wc -c < "$e" 2>/dev/null || echo 0)"; else printf '%s_err_bytes=0\n' "$mode"; fi
  done
}
webui_read() {
  mode="${1:-online}"
  offset="${2:-0}"
  count="${3:-4096}"
  case "$mode" in online|local) : ;; *) mode=online ;; esac
  case "$offset" in ''|*[!0-9]*) offset=0 ;; esac
  case "$count" in ''|*[!0-9]*) count=4096 ;; esac
  [ "$count" -gt 8192 ] 2>/dev/null && count=8192
  f="$(webui_scan_file "$mode")"
  [ -f "$f" ] || exit 0
  dd if="$f" bs=1 skip="$offset" count="$count" 2>/dev/null || true
}
webui_config_set_allowlist() {
  ids="${*:-}"
  if [ -z "$ids" ]; then
    config_auto 0 ""
  else
    config_auto 1 "$ids"
  fi
}



# WebUI v0.1.1-dev16 bridge-safe helpers. Commands below return one physical stdout
# line or base64 chunks so WebView bridges that drop/truncate multi-line stdout still
# work. dev4 file-backed scan helpers remain the data source.
webui_status_line() {
  mkdir -p "$(webui_dir)"
  job="$(webui_job_file)"
  if [ ! -s "$job" ]; then webui_write_job idle none "" "" "no_job"; fi
  status=""; mode=""; updated=""; pid=""; rc=""; message=""
  # shellcheck disable=SC1090
  . "$job" 2>/dev/null || true
  online_f="$(webui_scan_file online)"; online_e="$(webui_err_file online)"
  local_f="$(webui_scan_file local)"; local_e="$(webui_err_file local)"
  online_bytes=0; online_err_bytes=0; local_bytes=0; local_err_bytes=0
  [ -f "$online_f" ] && online_bytes="$(wc -c < "$online_f" 2>/dev/null || echo 0)"
  [ -f "$online_e" ] && online_err_bytes="$(wc -c < "$online_e" 2>/dev/null || echo 0)"
  [ -f "$local_f" ] && local_bytes="$(wc -c < "$local_f" 2>/dev/null || echo 0)"
  [ -f "$local_e" ] && local_err_bytes="$(wc -c < "$local_e" 2>/dev/null || echo 0)"
  # Keep this a single line. Values are normalized to avoid shell/newline surprises.
  message="$(printf '%s' "${message:-}" | tr '\n; ' '___')"
  printf 'status=%s;mode=%s;updated=%s;pid=%s;rc=%s;message=%s;online_bytes=%s;online_err_bytes=%s;local_bytes=%s;local_err_bytes=%s\n' \
    "${status:-unknown}" "${mode:-}" "${updated:-}" "${pid:-}" "${rc:-}" "${message:-}" \
    "$online_bytes" "$online_err_bytes" "$local_bytes" "$local_err_bytes"
}
webui_read_b64() {
  mode="${1:-online}"
  offset="${2:-0}"
  count="${3:-3072}"
  case "$mode" in online|local) : ;; *) mode=online ;; esac
  case "$offset" in ''|*[!0-9]*) offset=0 ;; esac
  case "$count" in ''|*[!0-9]*) count=3072 ;; esac
  [ "$count" -gt 4096 ] 2>/dev/null && count=4096
  f="$(webui_scan_file "$mode")"
  [ -f "$f" ] || { printf '\n'; exit 0; }
  dd if="$f" bs=1 skip="$offset" count="$count" 2>/dev/null | base64 | tr -d '\n'
  printf '\n'
}
webui_marker_dry_run_line() {
  mkdir -p "$(webui_dir)"
  out="$(webui_dir)/marker-dry-run.out"
  err="$(webui_dir)/marker-dry-run.err"
  if trigger_needed --dry-run --mode marker > "$out" 2> "$err"; then xrc=0; else xrc=$?; fi
  would="$(grep -E '^trigger_needed_dry_run_would_trigger=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
  scanned="$(grep -E '^trigger_needed_scanned=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
  bytes="$(wc -c < "$out" 2>/dev/null || echo 0)"
  err_bytes="$(wc -c < "$err" 2>/dev/null || echo 0)"
  printf 'status=%s;rc=%s;would_trigger=%s;scanned=%s;bytes=%s;err_bytes=%s\n' \
    "$([ "$xrc" = 0 ] && echo ok || echo failed)" "$xrc" "${would:-0}" "${scanned:-0}" "$bytes" "$err_bytes"
}
webui_auto_dry_run_line() {
  mkdir -p "$(webui_dir)"
  out="$(webui_dir)/auto-dry-run.out"
  err="$(webui_dir)/auto-dry-run.err"
  if auto_trigger --dry-run > "$out" 2> "$err"; then xrc=0; else xrc=$?; fi
  would="$(grep -E '^auto_trigger_dry_run_would_trigger=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
  bytes="$(wc -c < "$out" 2>/dev/null || echo 0)"
  err_bytes="$(wc -c < "$err" 2>/dev/null || echo 0)"
  printf 'status=%s;rc=%s;would_trigger=%s;bytes=%s;err_bytes=%s\n' \
    "$([ "$xrc" = 0 ] && echo ok || echo failed)" "$xrc" "${would:-0}" "$bytes" "$err_bytes"
}
webui_output_read_b64() {
  name="${1:-marker-dry-run.out}"
  offset="${2:-0}"
  count="${3:-3072}"
  case "$name" in marker-dry-run.out|marker-dry-run.err|auto-dry-run.out|auto-dry-run.err|scan-online.err|scan-local.err|job.env) : ;; *) name=marker-dry-run.out ;; esac
  case "$offset" in ''|*[!0-9]*) offset=0 ;; esac
  case "$count" in ''|*[!0-9]*) count=3072 ;; esac
  [ "$count" -gt 4096 ] 2>/dev/null && count=4096
  f="$(webui_dir)/$name"
  [ -f "$f" ] || { printf '\n'; exit 0; }
  dd if="$f" bs=1 skip="$offset" count="$count" 2>/dev/null | base64 | tr -d '\n'
  printf '\n'
}
webui_cache_clear() {
  mkdir -p "$(webui_dir)"
  rm -f "$(webui_dir)"/scan-online.json "$(webui_dir)"/scan-online.err "$(webui_dir)"/scan-local.json "$(webui_dir)"/scan-local.err "$(webui_dir)"/*.tmp
  webui_write_job idle none "" "" "cache_cleared"
  webui_status_line
}



# WebUI v0.1.1-dev16 safe-action helpers. Long safe actions run in the background
# so the WebView bridge never blocks on trigger-needed/config/auto dry-run output.
webui_action_env() { printf '%s/action.env' "$(webui_dir)"; }
webui_action_out() { printf '%s/action.out' "$(webui_dir)"; }
webui_action_err() { printf '%s/action.err' "$(webui_dir)"; }
webui_action_write() {
  mkdir -p "$(webui_dir)"
  status="$1"; action="$2"; pid="${3:-}"; rc="${4:-}"; message="${5:-}"
  message="$(printf '%s' "$message" | tr '\n; ' '___')"
  {
    printf 'status=%s\n' "$status"
    printf 'action=%s\n' "$action"
    printf 'updated=%s\n' "$(date +%s)"
    printf 'pid=%s\n' "$pid"
    printf 'rc=%s\n' "$rc"
    printf 'message=%s\n' "$message"
  } > "$(webui_action_env)"
}
webui_action_status_line() {
  mkdir -p "$(webui_dir)"
  envf="$(webui_action_env)"
  [ -s "$envf" ] || webui_action_write idle none "" "" no_action
  status=""; action=""; updated=""; pid=""; rc=""; message=""
  . "$envf" 2>/dev/null || true
  out="$(webui_action_out)"; err="$(webui_action_err)"
  bytes=0; err_bytes=0
  [ -f "$out" ] && bytes="$(wc -c < "$out" 2>/dev/null || echo 0)"
  [ -f "$err" ] && err_bytes="$(wc -c < "$err" 2>/dev/null || echo 0)"
  would=""; scanned=""
  case "${action:-}" in
    marker-dry-run)
      would="$(grep -E '^trigger_needed_dry_run_would_trigger=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
      scanned="$(grep -E '^trigger_needed_scanned=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
      ;;
    auto-dry-run)
      would="$(grep -E '^auto_trigger_dry_run_would_trigger=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
      ;;
  esac
  if [ "${status:-}" = running ] && [ -n "${pid:-}" ] && ! kill -0 "$pid" 2>/dev/null; then
    status=stale
    message=pid_not_alive
  fi
  printf 'status=%s;action=%s;updated=%s;pid=%s;rc=%s;message=%s;bytes=%s;err_bytes=%s;would_trigger=%s;scanned=%s\n' \
    "${status:-unknown}" "${action:-}" "${updated:-}" "${pid:-}" "${rc:-}" "${message:-}" "$bytes" "$err_bytes" "${would:-0}" "${scanned:-0}"
}
webui_action_start() {
  action="${1:-marker-dry-run}"
  case "$action" in marker-dry-run|auto-dry-run|config-show|config-disable) : ;; *) action=marker-dry-run ;; esac
  mkdir -p "$(webui_dir)"
  out="$(webui_action_out)"; err="$(webui_action_err)"
  rm -f "$out" "$err"
  self="$0"
  (
    xrc=0
    case "$action" in
      marker-dry-run) "$self" trigger-needed --dry-run --mode marker > "$out" 2> "$err" || xrc=$? ;;
      auto-dry-run) "$self" auto-trigger --dry-run > "$out" 2> "$err" || xrc=$? ;;
      config-show) "$self" config-show > "$out" 2> "$err" || xrc=$? ;;
      config-disable) "$self" config-auto --disable > "$out" 2> "$err" || xrc=$?; "$self" config-show >> "$out" 2>> "$err" || xrc=$? ;;
    esac
    if [ "$xrc" = 0 ]; then webui_action_write ok "$action" "$BASHPID" "$xrc" done; else webui_action_write failed "$action" "$BASHPID" "$xrc" failed; fi
  ) &
  bgpid="$!"
  webui_action_write running "$action" "$bgpid" "" started
  webui_action_status_line
}
webui_action_output_b64() {
  kind="${1:-out}"; offset="${2:-0}"; count="${3:-3072}"
  case "$kind" in out) f="$(webui_action_out)" ;; err) f="$(webui_action_err)" ;; *) f="$(webui_action_out)" ;; esac
  case "$offset" in ''|*[!0-9]*) offset=0 ;; esac
  case "$count" in ''|*[!0-9]*) count=3072 ;; esac
  [ "$count" -gt 4096 ] 2>/dev/null && count=4096
  [ -f "$f" ] || { printf '\n'; exit 0; }
  dd if="$f" bs=1 skip="$offset" count="$count" 2>/dev/null | base64 | tr -d '\n'
  printf '\n'
}




# mrt-auto-trigger-dev15-override:start
auto_trigger_load_config() {
  cfg="${CONFIG_FILE:-${MRT_CONFIG_FILE:-/data/adb/module-reflash-trigger/config.env}}"
  [ -f "$cfg" ] && . "$cfg" 2>/dev/null || true
}

auto_trigger_config_ids() {
  auto_trigger_load_config
  ids="${MRT_AUTO_TRIGGER_MODULE_IDS:-}"
  if [ -z "$ids" ] && [ -n "${MRT_AUTO_TRIGGER_PROFILE:-}" ]; then
    ids="$(auto_profile_ids "${MRT_AUTO_TRIGGER_PROFILE:-morphe}" 2>/dev/null | tr '\n' ' ')"
  fi
  # shell word-splitting is intentional here: config contains a space-separated allowlist.
  for id in $ids; do
    [ -n "$id" ] && printf '%s\n' "$id"
  done
}

auto_trigger_deny_id() {
  case "${1:-}" in
    ''|module-reflash-trigger|*rvmm*|*zygisk-mount*|*zygisk_mount*) return 0 ;;
  esac
  return 1
}

auto_trigger_json_field() {
  key="${1:-}"
  sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p"
}

auto_trigger_dry_run() {
  auto_trigger_load_config
  enabled="${MRT_AUTO_TRIGGER_ENABLED:-0}"
  on_boot="${MRT_AUTO_TRIGGER_ON_BOOT:-0}"
  profile="${MRT_AUTO_TRIGGER_PROFILE:-}"
  printf 'AUTO_TRIGGER_START mode=dry-run source=config-status\n'
  printf 'auto_trigger_config enabled=%s on_boot=%s profile=%s ids=%s\n' "$enabled" "$on_boot" "$profile" "${MRT_AUTO_TRIGGER_MODULE_IDS:-}"

  if [ "$enabled" != "1" ]; then
    printf 'auto_trigger_skip reason=disabled enabled=%s\n' "$enabled"
    printf 'auto_trigger_dry_run_would_trigger=0\n'
    printf 'auto_trigger_scanned=0\n'
    return 0
  fi

  scanned=0
  count=0
  for id in $(auto_trigger_config_ids); do
    scanned=$((scanned + 1))
    if auto_trigger_deny_id "$id"; then
      printf 'SKIP module=%s status=denied reason=auto_profile_deny\n' "$id"
      continue
    fi
    js="$(status_one "$id" 1 json 2>/dev/null || true)"
    status="$(printf '%s' "$js" | auto_trigger_json_field status | tail -1)"
    reason="$(printf '%s' "$js" | auto_trigger_json_field reason | tail -1)"
    [ -n "$status" ] || status=unknown
    [ -n "$reason" ] || reason=none
    if [ "$status" = "needs_reflash" ]; then
      printf 'WOULD_TRIGGER module=%s status=%s reason=%s\n' "$id" "$status" "$reason"
      count=$((count + 1))
    else
      printf 'SKIP module=%s status=%s reason=%s\n' "$id" "$status" "$reason"
    fi
  done
  printf 'auto_trigger_dry_run_would_trigger=%s\n' "$count"
  printf 'auto_trigger_scanned=%s\n' "$scanned"
  return 0
}

auto_trigger() {
  confirm="${1:-0}"
  if [ "$confirm" != "1" ]; then
    printf 'ERROR: auto-trigger real mode requires --yes\n' >&2
    return 2
  fi

  rt="${MRT_RUNTIME_DIR:-/data/adb/module-reflash-trigger}"
  tmpdir="$rt/tmp"
  mkdir -p "$tmpdir" 2>/dev/null || tmpdir="${TMPDIR:-/data/local/tmp}"
  out="$tmpdir/mrt-auto-trigger.$$.out"
  errf="$tmpdir/mrt-auto-trigger.$$.err"
  : > "$out"
  : > "$errf"

  printf 'AUTO_TRIGGER_START mode=yes source=config-status-replay\n'
  dry_rc=0
  auto_trigger_dry_run > "$out" 2> "$errf" || dry_rc=$?
  cat "$out" 2>/dev/null || true
  if [ -s "$errf" ]; then
    printf 'AUTO_TRIGGER_DRYRUN_STDERR_BEGIN\n' >&2
    cat "$errf" >&2 2>/dev/null || true
    printf 'AUTO_TRIGGER_DRYRUN_STDERR_END\n' >&2
  fi

  would="$(grep -E '^auto_trigger_dry_run_would_trigger=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
  case "$would" in ''|*[!0-9]*) would=0 ;; esac

  triggered=0
  failed=0
  seen=0
  while IFS= read -r line; do
    case "$line" in
      WOULD_TRIGGER\ module=*)
        id="${line#WOULD_TRIGGER module=}"
        id="${id%% *}"
        [ -n "$id" ] || continue
        seen=$((seen + 1))
        printf 'AUTO_TRIGGER_CANDIDATE module=%s\n' "$id"
        if trigger_one "$id" 1 0; then
          triggered=$((triggered + 1))
          printf 'AUTO_TRIGGER_TRIGGERED module=%s\n' "$id"
        else
          rc=$?
          failed=$((failed + 1))
          printf 'AUTO_TRIGGER_FAILED module=%s rc=%s\n' "$id" "$rc" >&2
        fi
        ;;
    esac
  done < "$out"

  printf 'AUTO_TRIGGER_DONE triggered=%s failed=%s dry_run_would_trigger=%s parsed_candidates=%s dry_run_rc=%s\n' "$triggered" "$failed" "$would" "$seen" "$dry_rc"
  printf 'auto_triggered=%s\n' "$triggered"
  rm -f "$out" "$errf" 2>/dev/null || true
  if [ "$dry_rc" != "0" ] || { [ "$would" -gt 0 ] && [ "$triggered" = "0" ]; }; then
    return 1
  fi
  [ "$failed" = "0" ] || return 1
  return 0
}
# mrt-auto-trigger-dev15-override:end


# mrt-auto-trigger-dev16-override:start
auto_trigger() {
  confirm="${1:-0}"
  if [ "$confirm" != "1" ]; then
    printf 'ERROR: auto-trigger real mode requires --yes\n' >&2
    return 2
  fi

  rt="${MRT_RUNTIME_DIR:-/data/adb/module-reflash-trigger}"
  tmpdir="$rt/tmp"
  mkdir -p "$tmpdir" 2>/dev/null || tmpdir="${TMPDIR:-/data/local/tmp}"
  out="$tmpdir/mrt-auto-trigger.$$.out"
  errf="$tmpdir/mrt-auto-trigger.$$.err"
  : > "$out"
  : > "$errf"

  printf 'AUTO_TRIGGER_START mode=yes source=dev16-config-status-force-replay\n'

  dry_rc=0
  "$0" auto-trigger --dry-run > "$out" 2> "$errf" || dry_rc=$?

  cat "$out" 2>/dev/null || true
  if [ -s "$errf" ]; then
    printf 'AUTO_TRIGGER_DRYRUN_STDERR_BEGIN\n' >&2
    cat "$errf" >&2 2>/dev/null || true
    printf 'AUTO_TRIGGER_DRYRUN_STDERR_END\n' >&2
  fi

  would="$(grep -E '^auto_trigger_dry_run_would_trigger=' "$out" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
  case "$would" in ''|*[!0-9]*) would=0 ;; esac

  triggered=0
  failed=0
  seen=0
  while IFS= read -r line; do
    case "$line" in
      WOULD_TRIGGER\ module=*)
        id="${line#WOULD_TRIGGER module=}"
        id="${id%% *}"
        [ -n "$id" ] || continue
        seen=$((seen + 1))
        printf 'AUTO_TRIGGER_CANDIDATE module=%s\n' "$id"

        case "$id" in module-reflash-trigger|''|*/*|*' '..*|*' '*)
          failed=$((failed + 1))
          printf 'AUTO_TRIGGER_FAILED module=%s rc=%s reason=unsafe_id\n' "$id" 90 >&2
          continue
          ;;
        esac
        mdir="/data/adb/modules/$id"
        if [ -e "$mdir/disable" ] || [ -e "$mdir/remove" ]; then
          failed=$((failed + 1))
          printf 'AUTO_TRIGGER_FAILED module=%s rc=%s reason=disabled_or_remove_marked\n' "$id" 91 >&2
          continue
        fi

        js="$(status_one "$id" 1 json 2>/dev/null || true)"
        status="$(printf '%s' "$js" | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')"
        reason="$(printf '%s' "$js" | sed -n 's/.*"reason":"\([^"]*\)".*/\1/p')"
        if [ "$status" != "needs_reflash" ]; then
          printf 'AUTO_TRIGGER_SKIP module=%s status=%s reason=status_changed current_reason=%s\n' "$id" "$status" "$reason"
          continue
        fi

        if trigger_one "$id" 1 1; then
          triggered=$((triggered + 1))
          printf 'AUTO_TRIGGER_TRIGGERED module=%s force=needs_reflash\n' "$id"
        else
          rc=$?
          failed=$((failed + 1))
          printf 'AUTO_TRIGGER_FAILED module=%s rc=%s\n' "$id" "$rc" >&2
        fi
        ;;
    esac
  done < "$out"

  rm -f "$out" "$errf" 2>/dev/null || true

  printf 'AUTO_TRIGGER_DONE triggered=%s failed=%s dry_run_would_trigger=%s parsed_candidates=%s dry_run_rc=%s force=needs_reflash\n' "$triggered" "$failed" "$would" "$seen" "$dry_rc"
  printf 'auto_triggered=%s\n' "$triggered"

  if [ "$dry_rc" -ne 0 ]; then
    return "$dry_rc"
  fi
  if [ "$would" -gt 0 ] && [ "$seen" -eq 0 ]; then
    printf 'ERROR: auto-trigger dry-run reported %s candidates but parsed zero\n' "$would" >&2
    return 1
  fi
  if [ "$would" -gt 0 ] && [ "$triggered" -eq 0 ]; then
    printf 'ERROR: auto-trigger dry-run reported %s candidates but triggered zero\n' "$would" >&2
    return 1
  fi
  if [ "$failed" -gt 0 ]; then
    return 1
  fi
  return 0
}
# mrt-auto-trigger-dev16-override:end

case "$cmd" in
  webui-action-start) webui_action_start "${2:-marker-dry-run}" ;;
  webui-action-status-line) webui_action_status_line ;;
  webui-action-output-b64) webui_action_output_b64 "${2:-out}" "${3:-0}" "${4:-3072}" ;;
  webui-status-line) webui_status_line ;;
  webui-read-b64) webui_read_b64 "${2:-online}" "${3:-0}" "${4:-3072}" ;;
  webui-marker-dry-run-line) webui_marker_dry_run_line ;;
  webui-auto-dry-run-line) webui_auto_dry_run_line ;;
  webui-output-read-b64) webui_output_read_b64 "${2:-marker-dry-run.out}" "${3:-0}" "${4:-3072}" ;;
  webui-cache-clear) webui_cache_clear ;;
  webui-scan-start) webui_scan_start "${2:-online}" ;;
  __webui_scan_run) webui_scan_run "${2:-online}" ;;
  webui-status) webui_status ;;
  webui-read) webui_read "${2:-online}" "${3:-0}" "${4:-4096}" ;;
  webui-config-set-allowlist) shift; webui_config_set_allowlist "$@" ;;
  summary) summary ;;
  list|scan) scan 0 text ;;
  scan-json) scan 0 json ;;
  scan-online) scan 1 text ;;
  scan-online-json) scan 1 json ;;
  status) [ $# -ge 2 ] || { usage; exit 2; }; status_one "$2" 0 text ;;
  status-online) [ $# -ge 2 ] || { usage; exit 2; }; status_one "$2" 1 text ;;
  trigger)
    if [ "${2:-}" = "--force" ]; then [ "${3:-}" = "--yes" ] && [ $# -ge 4 ] || { usage; exit 2; }; trigger_one "$4" 1 1
    elif [ "${2:-}" = "--yes" ]; then [ $# -ge 3 ] || { usage; exit 2; }; trigger_one "$3" 1 0
    else [ $# -ge 2 ] || { usage; exit 2; }; trigger_one "$2" 0 0
    fi ;;
  restore-latest) [ $# -ge 2 ] || { usage; exit 2; }; restore_latest "$2" ;;
  mark-fresh)
    if [ "${2:-}" = "--cached" ]; then [ $# -ge 3 ] || { usage; exit 2; }; mark_fresh "$3" cached
    else [ $# -ge 2 ] || { usage; exit 2; }; mark_fresh "$2" remote
    fi ;;
  baseline-show)
    if [ "${2:-}" = "--online" ]; then [ $# -ge 3 ] || { usage; exit 2; }; baseline_show "$3" 1
    else [ $# -ge 2 ] || { usage; exit 2; }; baseline_show "$2" 0
    fi ;;
  clear-baseline) [ $# -ge 2 ] || { usage; exit 2; }; shift; clear_baseline "$@" ;;
  test-mark-stale) [ $# -ge 2 ] || { usage; exit 2; }; test_mark_stale "$2" ;;
  trigger-needed) shift; trigger_needed "$@" ;;
  action) action_button ;;
  auto-trigger)
    if [ "${2:-}" = "--dry-run" ]; then auto_trigger_dry_run
    elif [ "${2:-}" = "--yes" ]; then auto_trigger 1
    else usage; exit 2; fi ;;
  auto-ids) auto_profile_ids "${2:-morphe}" ;;
  config-show) config_show ;;
  config-auto) shift; write_config_auto "$@" ;;
  help|-h|--help) usage ;;
  *) usage; exit 2 ;;
esac
